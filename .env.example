# =============================================================================
# NSI Bot Environment Configuration
# Copy this to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- LLM Providers ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=moonshotai/kimi-k2.5

OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-haiku-20240307

# --- Research Agent (Perplexity) — V2 feature, not needed for V1 ---
# PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxx
# PERPLEXITY_BASE_URL=https://api.perplexity.ai
# PERPLEXITY_MODEL=sonar

# --- Google Drive ---
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/gdrive-sa.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Microsoft 365 Email ---
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EMAIL_FROM=your-email@example.com
EMAIL_ALWAYS_CC=cc-email@example.com
EMAIL_P0_CC=priority-email@example.com

# --- OpenClaw ---
OPENCLAW_WS_URL=ws://localhost:3000/gateway
OPENCLAW_API_KEY=

# --- Database ---
DB_PATH=data/nsi.db

# --- Dashboard ---
DASHBOARD_SECRET_KEY=change-this-to-a-random-64-char-string
DASHBOARD_SESSION_HOURS=24

# --- Bot ---
BOT_MENTION_TAG=@nsi
QUIET_WINDOW_START_HOUR=2
QUIET_WINDOW_END_HOUR=8
CHASER_INTERVAL_MINUTES=60
CONTEXT_BUFFER_TIMEOUT_MINUTES=10

# --- Webhook ---
WEBHOOK_PATH=/api/webhook
IDEMPOTENCY_TTL_SECONDS=3600

# --- Exchange Rates (hardcoded) ---
INR_TO_USD=91
